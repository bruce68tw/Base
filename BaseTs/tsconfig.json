{
  "compilerOptions": {
    //"module": "ESNext", // ES Module
    //"target": "ES2022", // 編譯版本
    //"moduleResolution": "Bundler", // Vite相容解析
    "module": "None",
    "target": "ES5",
    "ignoreDeprecations": "6.0",
    "outDir": "_dist/jsBase", //JavaScript 輸出目錄
    "strict": false, // 舊JS轉TS較容易
    "skipLibCheck": true, // 忽略第三方型別
    "types": [ "jquery", "jquery.validation", "datatables.net" ]
  },
  "include": [
    "global.d.ts",
    "**/*.ts"
  ],
  "exclude": [
    "node_modules" //排除 npm 套件
  ]
}